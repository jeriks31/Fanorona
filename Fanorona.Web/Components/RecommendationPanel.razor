<div class="panel">
    <h2>Your move</h2>
    @if (Result is { } result)
    {
        <div class="rec-move">@Notation.Format(result.BestTurn)</div>
        <div class="rec-meta">
            depth @result.DepthReached · @DescribeScore(result.Score) · @result.Nodes.ToString("N0") nodes
            @if (Thinking)
            {
                <span class="thinking"> · <span class="spinner"></span>thinking…</span>
            }
        </div>
        <ol class="steps">
            @foreach (var step in MoveDescriber.Steps(result.BestTurn))
            {
                <li>@step</li>
            }
        </ol>
        <div class="btn-row">
            <button class="btn primary" @onclick="() => OnPlayed.InvokeAsync()">✓ I played it</button>
            <button class="btn" @onclick="() => OnDifferent.InvokeAsync()">I played a different move</button>
            @if (Thinking)
            {
                <button class="btn" @onclick="() => OnStop.InvokeAsync()">Stop thinking</button>
            }
            else
            {
                <button class="btn" @onclick="() => OnRethink.InvokeAsync()">Re-think</button>
            }
        </div>
    }
    else
    {
        <p class="thinking"><span class="spinner"></span>Thinking…</p>
    }
</div>

@code {
    [Parameter] public SearchResult? Result { get; set; }
    [Parameter] public bool Thinking { get; set; }
    [Parameter] public EventCallback OnPlayed { get; set; }
    [Parameter] public EventCallback OnDifferent { get; set; }
    [Parameter] public EventCallback OnStop { get; set; }
    [Parameter] public EventCallback OnRethink { get; set; }

    // Scores are from the engine side's perspective, and the engine side is you.
    private static string DescribeScore(int score)
    {
        if (score > 900_000)
            return $"forced win for you in {(Evaluation.Win - score + 1) / 2} move(s)";
        if (score < -900_000)
            return $"forced loss for you in {(Evaluation.Win + score + 1) / 2} move(s)";
        return $"eval {score / 100.0:+0.0;-0.0;+0.0} pieces";
    }
}
